# Local Proxy — подключение к удалённому серверу

# Адрес NestJS сервера (IP или домен)
WS_HOST=localhost

# Порт NestJS сервера
WS_PORT=8080

# Включить WSS (wss://) — нужно если сервер за HTTPS
# WS_SSL=true

# Полный URL WebSocket (переопределяет WS_HOST/WS_PORT/WS_SSL)
# WS_URL=wss://tunnel.example.com

# Порт SOCKS5 на локальной машине
SOCKS5_PORT=1080
